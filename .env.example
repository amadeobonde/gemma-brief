# Copy this file to `.env` and fill in your own values.

# Spotify Developer App credentials.
# Create one at https://developer.spotify.com/dashboard.
# Add this redirect URI to the app: http://127.0.0.1:3000/discovery
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Filled in automatically by `podcastbrief auth-spotify --write-env`.
SPOTIFY_REFRESH_TOKEN=

# The Spotify playlist that holds podcast episodes you want briefed.
# Get the ID from the playlist URL: open.spotify.com/playlist/<ID>
SPOTIFY_PLAYLIST_ID=

# Telegram Bot API.
# Create a bot via @BotFather: https://t.me/BotFather → /newbot.
TELEGRAM_BOT_TOKEN=

# Comma-separated chat IDs to send daily briefs to.
# Each chat must have started a conversation with the bot once (or the bot
# must be a member of the group). Get an ID by messaging @userinfobot.
TELEGRAM_CHAT_IDS=

# Ollama. Use 127.0.0.1 (not localhost) on macOS to hit the native daemon
# instead of any Docker-bound IPv6 socket — that gives the model the full
# host RAM (Gemma 4 E4B needs ~10 GB).
OLLAMA_HOST=http://127.0.0.1:11434
LLM_MODEL=gemma4:e4b

# faster-whisper OpenAI-compatible HTTP server. The Docker compose file ships
# with one mapped to host port 9000. If you run your own, set its URL here.
WHISPER_URL=http://localhost:9000
WHISPER_TIMEOUT_SECONDS=1800

# Gotenberg HTML→PDF service. Docker compose ships one on host port 3000.
GOTENBERG_URL=http://localhost:3000

# Telegram voice-reply TTS. macOS `say` voice + words-per-minute rate.
# `say -v '?'` lists installed voices. For natural output, download Apple's
# premium neural voices via System Settings -> Accessibility -> Spoken Content
# -> System Voice -> Manage Voices, then set this to e.g. "Ava (Premium)" or
# "Zoe (Premium)" or "Siri Voice 1".
TTS_VOICE=Samantha
TTS_RATE=185

# FRED API key for macro indicator enrichment.
# Free, instant: https://fred.stlouisfed.org/docs/api/api_key.html
# If blank, the FRED enricher is skipped silently (no macro charts).
FRED_API_KEY=

# RSS feeds the "Reality check" enricher polls for contemporaneous headlines.
# Comma-separated. Override to add/remove sources.
RSS_NEWS_FEEDS=https://feeds.reuters.com/reuters/businessNews,https://www.ft.com/rss/home,https://feeds.bbci.co.uk/news/business/rss.xml,https://feeds.bbci.co.uk/news/world/rss.xml

# Where the markdown brief vault and rendered PDFs live (relative or absolute).
NOTES_DIR=./podcast_notes
PDF_OUT_DIR=./briefs

LOG_LEVEL=INFO
