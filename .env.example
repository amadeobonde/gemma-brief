# Copy this file to `.env` and fill in your own values.
# Run `gemma-brief setup` for an interactive wizard that generates this for you.

# ── YouTube Playlists (required) ─────────────────────────────────────────────
# One or more YouTube playlist URLs, comma-separated.
# Requires yt-dlp — scripts/install.sh installs it, or: pip install yt-dlp
# Example: https://www.youtube.com/playlist?list=PLxxxxxxxxxxxxxxxxxx
YOUTUBE_PLAYLIST_URLS=

# ── Telegram Bot ─────────────────────────────────────────────────────────────
# Create a bot via @BotFather: https://t.me/BotFather → /newbot
TELEGRAM_BOT_TOKEN=

# Comma-separated chat IDs to send daily briefs to.
# Each chat must have started a conversation with the bot (or the bot is a group member).
# Get an ID by messaging @userinfobot.
TELEGRAM_CHAT_IDS=

# ── Gemma model / Ollama ─────────────────────────────────────────────────────
# Pick any model from the Gemma 2 / 3 / 4 suite. `gemma-brief setup` shows a
# RAM-aware selector and sets these automatically.
#
# Gemma 4 (multimodal, vision, 128K ctx)     RAM needed
#   gemma4:e2b   fastest, fits 8 GB          ~7 GB
#   gemma4:e4b   recommended                ~12 GB  ← default
#   gemma4:12b   higher quality             ~16 GB
#   gemma4:27b   max quality                ~35 GB
#
# Gemma 3 (text-only, 128K ctx)
#   gemma3:4b    lightweight                 ~6 GB
#   gemma3:12b   balanced                   ~12 GB
#   gemma3:27b   best text quality          ~24 GB
#
# Gemma 2 (text-only, 8K ctx)
#   gemma2:2b    ultra light                 ~4 GB
#   gemma2:9b    compact                     ~8 GB
#   gemma2:27b   largest Gemma 2            ~22 GB
#
# Use 127.0.0.1 (not localhost) on macOS / Linux to avoid IPv6 resolving
# to the Docker socket. On Windows WSL 2, use host.docker.internal:11434.
OLLAMA_HOST=http://127.0.0.1:11434
LLM_MODEL=gemma4:e4b

# Context window + output budget — set automatically by `gemma-brief setup`.
# Gemma 4/3: 32768 / 6144  |  Gemma 2: 8192 / 4096
# Lower LLM_NUM_CTX on memory-constrained machines.
LLM_NUM_CTX=32768
LLM_NUM_PREDICT=6144

# ── Whisper (transcription) ───────────────────────────────────────────────────
# faster-whisper OpenAI-compatible HTTP server.
# Docker compose ships one mapped to host port 9000.
WHISPER_URL=http://localhost:9000
WHISPER_TIMEOUT_SECONDS=1800

# ── Gotenberg (PDF rendering) ─────────────────────────────────────────────────
# HTML→PDF service. Docker compose ships one on host port 3000.
GOTENBERG_URL=http://localhost:3000

# ── TTS (voice replies) ───────────────────────────────────────────────────────
# TTS_BACKEND: auto (detect by OS), say (macOS), espeak (Linux), pyttsx3, off
# auto → macOS uses `say`, Linux uses espeak-ng, Windows uses pyttsx3.
TTS_BACKEND=auto
# macOS `say` voice. `say -v '?'` lists all voices.
# Premium neural: "Ava (Premium)", "Zoe (Premium)", "Evan (Premium)"
# (System Settings → Accessibility → Spoken Content → Manage Voices)
TTS_VOICE=Samantha
TTS_RATE=185

# ── Optional: RSS news enrichment ────────────────────────────────────────────
# Comma-separated RSS feeds polled for contemporaneous headlines.
RSS_NEWS_FEEDS=https://feeds.reuters.com/reuters/businessNews,https://www.ft.com/rss/home,https://feeds.bbci.co.uk/news/business/rss.xml,https://feeds.bbci.co.uk/news/world/rss.xml

# ── Optional: RSS podcast feeds ─────────────────────────────────────────────
# Comma-separated RSS feed URLs — one per show. Covers every platform.
# Find a show's RSS via podcastaddict.com or castpodder.net.
RSS_PODCAST_FEEDS=

# ── Paths ─────────────────────────────────────────────────────────────────────
NOTES_DIR=./podcast_notes
PDF_OUT_DIR=./briefs

# Persistent store of original episode audio (MP3/M4A). Required by /debate.
AUDIO_STORE_PATH=./podcast_notes/audio_store

# /debate audio tunables (defaults shown).
CLIP_PADDING_SECONDS=0.75
CLIP_SILENCE_BETWEEN_MS=800
CLIP_TARGET_DBFS=-18.0

# Daily brief schedule — 24-h HH:MM, server local time.
# Change with:  gemma-brief schedule HH:MM
DAILY_BRIEF_TIME=02:00

LOG_LEVEL=INFO
