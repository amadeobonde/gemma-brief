# Copy this file to `.env` and fill in your own values.
# Run `podcastbrief setup` for an interactive wizard that generates this for you.

# ── YouTube Playlists (required) ────────────────────────────────────────────
# One or more YouTube playlist URLs, comma-separated.
# Requires yt-dlp — scripts/install.sh installs it, or: pip install yt-dlp
# Example: https://www.youtube.com/playlist?list=PLxxxxxxxxxxxxxxxxxx
YOUTUBE_PLAYLIST_URLS=

# ── Telegram Bot ─────────────────────────────────────────────────────────────
# Create a bot via @BotFather: https://t.me/BotFather → /newbot
TELEGRAM_BOT_TOKEN=

# Comma-separated chat IDs to send daily briefs to.
# Each chat must have started a conversation with the bot (or the bot is a group member).
# Get an ID by messaging @userinfobot.
TELEGRAM_CHAT_IDS=

# ── Gemma 4 / Ollama ─────────────────────────────────────────────────────────
# Use 127.0.0.1 (not localhost) on macOS to hit the native Ollama daemon
# and give the model the full host RAM (Gemma 4 E4B needs ~10 GB).
OLLAMA_HOST=http://127.0.0.1:11434
LLM_MODEL=gemma4:e4b

# ── Whisper (transcription) ───────────────────────────────────────────────────
# faster-whisper OpenAI-compatible HTTP server.
# Docker compose ships one mapped to host port 9000.
WHISPER_URL=http://localhost:9000
WHISPER_TIMEOUT_SECONDS=1800

# ── Gotenberg (PDF rendering) ─────────────────────────────────────────────────
# HTML→PDF service. Docker compose ships one on host port 3000.
GOTENBERG_URL=http://localhost:3000

# ── Telegram voice-reply TTS ─────────────────────────────────────────────────
# macOS `say` voice + words-per-minute rate.
# `say -v '?'` lists installed voices. Premium neural voices:
# System Settings → Accessibility → Spoken Content → System Voice → Manage Voices
TTS_VOICE=Samantha
TTS_RATE=185

# ── Optional: FRED macro enrichment ─────────────────────────────────────────
# Free, instant key: https://fred.stlouisfed.org/docs/api/api_key.html
# If blank, macro charts are skipped silently.
FRED_API_KEY=

# ── Optional: RSS news enrichment ────────────────────────────────────────────
# Comma-separated RSS feeds polled for contemporaneous headlines.
RSS_NEWS_FEEDS=https://feeds.reuters.com/reuters/businessNews,https://www.ft.com/rss/home,https://feeds.bbci.co.uk/news/business/rss.xml,https://feeds.bbci.co.uk/news/world/rss.xml

# ── Optional: RSS podcast feeds ─────────────────────────────────────────────
# Comma-separated RSS feed URLs — one per show. Covers every platform.
# Find a show's RSS via podcastaddict.com or castpodder.net.
RSS_PODCAST_FEEDS=

# ── Paths ─────────────────────────────────────────────────────────────────────
NOTES_DIR=./podcast_notes
PDF_OUT_DIR=./briefs

# Persistent store of original episode audio (MP3/M4A). Required by /debate.
# Populated automatically; backfill existing episodes with `podcastbrief redownload-audio`.
AUDIO_STORE_PATH=./podcast_notes/audio_store

# /debate audio tunables (defaults shown).
CLIP_PADDING_SECONDS=0.75
CLIP_SILENCE_BETWEEN_MS=800
CLIP_TARGET_DBFS=-18.0

LOG_LEVEL=INFO
